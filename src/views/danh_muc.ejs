<!-- View Danh mục: danh sách toàn bộ danh mục sản phẩm. --><!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Danh mục sản phẩm">
    <title><%= title || 'Danh mục' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <%- include('styles') %>
</head>

<body>
    <%- include('thanh_menu') %>

    <section class="page-section">
        <h1 class="page-title"><%= title || 'Danh mục' %></h1>
        <p class="page-copy">Khám phá các danh mục nổi bật để tìm phong cách phù hợp với bạn.</p>
        <div class="cards-grid">
            <% if (categories && categories.length) { %>
                <!-- Nếu có danh mục, duyệt từng danh mục và hiển thị card -->
                <% categories.forEach(function(category) { %>
                    <article class="card-tile">
                        <% if (category.image) { %>
                            <!-- Hiển thị ảnh danh mục, nếu lỗi thì dùng ảnh dự phòng -->
                            <img src="<%= category.image %>" alt="<%= category.name %>" onerror="this.onerror=null;this.src='https://via.placeholder.com/600x600?text=No+Image'">
                        <% } else { %>
                            <img src="https://via.placeholder.com/600x600?text=No+Image" alt="Không có ảnh">
                        <% } %>
                        <div class="card-body">
                            <div class="card-label">Danh mục</div>
                            <h3 class="card-heading"><%= category.name %></h3>
                            <p class="card-text"><%= category.description || 'Danh mục chưa có mô tả.' %></p>
                            <a class="card-link" href="/san-pham?category=<%= category.slug %>">Xem sản phẩm</a>
                        </div>
                    </article>
                <% }); %>
            <% } else { %>
                    <!-- Thông báo khi không có danh mục nào được trả về từ server -->
                    <div class="alert">Chưa có danh mục nào để hiển thị.</div>
                <% } %>
    </section>

    <%- include('chan_trang') %>
</body>

</html>
