<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Thông tin tài khoản người dùng">
    <title><%= title || 'Tài khoản' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <%- include('styles') %>
</head>

<body>
    <%- include('thanh_menu') %>

    <section class="page-section account-page">
        <h1 class="page-title"><%= title || 'Tài khoản của tôi' %></h1>
        <p class="page-copy">Quản lý thông tin cá nhân và đơn hàng của bạn một cách chuyên nghiệp, nhanh chóng.</p>
        <div class="grid-2 account-grid">
            <div class="panel profile-panel">
                <div class="panel-body">
                    <span class="info-badge">Hồ sơ cá nhân</span>
                    <h2 class="panel-heading">Xin chào, <%= user?.name || 'Khách hàng' %></h2>
                    <p class="page-copy">Thông tin tài khoản của bạn được bảo mật và dễ dàng cập nhật khi cần.</p>
                    <div class="profile-summary">
                        <div><span>Họ tên</span><strong><%= user?.name || 'Khách hàng' %></strong></div>
                        <div><span>Email</span><strong><%= user?.email || 'email@domain.com' %></strong></div>
                        <div><span>Điện thoại</span><strong><%= user?.phone || 'Chưa có' %></strong></div>
                        <div><span>Quyền</span><strong><%= user?.role === 'manager' ? 'Quản lý' : user?.role === 'employee' ? 'Nhân viên' : user?.role === 'admin' ? 'Quản trị viên' : 'Khách hàng' %></strong></div>
                    </div>
                </div>
            </div>
            <div class="form-card profile-card">
                <div class="panel-body">
                    <h2 class="panel-heading">Cập nhật thông tin</h2>
                    <p class="page-copy">Chỉnh sửa thông tin cá nhân và địa chỉ giao hàng để nhận đơn nhanh hơn.</p>
                    <form action="/nguoi-dung/tai-khoan" method="post">
                        <div class="form-group">
                            <label for="name">Họ tên</label>
                            <input type="text" id="name" name="name" value="<%= user?.name || '' %>">
                        </div>
                        <div class="form-group">
                            <label for="phone">Số điện thoại</label>
                            <input type="text" id="phone" name="phone" value="<%= user?.phone || '' %>">
                        </div>
                        <div class="form-group">
                            <label for="street">Địa chỉ</label>
                            <input type="text" id="street" name="street" value="<%= user?.address?.street || '' %>">
                        </div>
                        <div class="form-actions">
                            <button type="submit" class="button-primary">Cập nhật</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <%- include('chan_trang') %>
</body>

</html>
