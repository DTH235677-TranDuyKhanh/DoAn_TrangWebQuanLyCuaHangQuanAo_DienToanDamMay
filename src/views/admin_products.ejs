<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Quản lý sản phẩm">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <%- include('styles') %>
</head>

<body>
    <%- include('thanh_menu') %>

    <section class="page-section">
        <div class="page-actions">
            <h1 class="page-title"><%= title %></h1>
            <a href="/admin/products/new" class="button-primary">Thêm sản phẩm mới</a>
        </div>
        <div class="panel">
            <div class="panel-body">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Tên sản phẩm</th>
                            <th>Danh mục</th>
                            <th>Giá</th>
                            <th>Trạng thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (products.length === 0) { %>
                            <tr>
                                <td colspan="5">Chưa có sản phẩm nào.</td>
                            </tr>
                        <% } %>
                        <% products.forEach(function(product) { %>
                            <tr>
                                <td><%= product.name %></td>
                                <td><%= product.category?.name || 'Chưa chọn' %></td>
                                <td><%= product.price.toLocaleString() %> ₫</td>
                                <td><%= product.isActive ? 'Đang hiển thị' : 'Ẩn' %></td>
                                <td>
                                    <a href="/admin/products/<%= product._id %>/edit" class="button-secondary">Sửa</a>
                                    <form action="/admin/products/<%= product._id %>/delete" method="post" style="display:inline-block; margin-left: 8px;">
                                        <button type="submit" class="button-secondary">Xóa</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <%- include('chan_trang') %>
</body>

</html>
