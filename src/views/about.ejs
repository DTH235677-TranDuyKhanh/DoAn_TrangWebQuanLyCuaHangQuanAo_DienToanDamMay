<!-- View About: trang giới thiệu thông tin cửa hàng. --><!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Về chúng tôi - Levi's style shop">
    <title><%= title || 'Về Chúng Tôi' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <%- include('styles') %>
</head>

<body>
    <%- include('thanh_menu') %>

    <section class="hero">
        <!-- Phần hero giới thiệu hình ảnh và thông điệp thương hiệu -->
        <div class="hero-left">
            <img src="https://vietnamrawdenim.com/wp-content/uploads/2023/04/vnrd-ff12-O1-1024x1024.jpg" alt="About us">
            <div class="hero-gradient"></div>
        </div>
        <div class="hero-right">
            <img src="https://images2.thanhnien.vn/uploaded/tuyendtb/2021_01_13/levis2_HVMQ.jpg?width=500" alt="Levi's story">
            <div class="hero-gradient"></div>
        </div>
        <div class="hero-content">
            <div class="hero-content-inner">
                <div class="hero-label">OUR STORY</div>
                <h1 class="hero-title">Tinh thần Denim Mỹ</h1>
                <p class="hero-copy">Levi's là biểu tượng của phong cách tự do, chất lượng và sự bền vững. Chúng tôi chọn nguyên liệu tốt, thiết kế tối giản và trải nghiệm mua sắm thân thiện.</p>
                <div class="hero-buttons">
                    <a class="hero-button" href="/san-pham">Khám phá sản phẩm</a>
                </div>
            </div>
        </div>
    </section>

    <section class="section">
        <h2 class="section-title">Tại sao chọn chúng tôi</h2>
        <p class="section-subtitle">Mỗi sản phẩm được chọn lọc và mang đến trải nghiệm mượt mà, hiện đại.</p>
        <div class="cards-grid">
            <article class="card-tile">
                <img src="https://images.unsplash.com/photo-1526170375885-4d8ecf77b99f?w=900&h=1200&fit=crop" alt="Quality">
                <div class="card-body">
                    <div class="card-label">Chất lượng</div>
                    <h3 class="card-heading">Denim cao cấp</h3>
                    <p class="card-text">Sản phẩm được lựa chọn với chất liệu bền bỉ và đường may tỉ mỉ.</p>
                </div>
            </article>
            <article class="card-tile">
                <img src="https://images.unsplash.com/photo-1512436991641-6745cdb1723f?w=900&h=1200&fit=crop" alt="Design">
                <div class="card-body">
                    <div class="card-label">Phong cách</div>
                    <h3 class="card-heading">Thiết kế không lỗi thời</h3>
                    <p class="card-text">Đường nét đơn giản, phù hợp với nhiều phong cách hàng ngày.</p>
                </div>
            </article>
            <article class="card-tile">
                <img src="https://www.elle.vn/wp-content/uploads/2018/03/02/elle-viet-nam-levi-1.jpg" alt="Responsibility">
                <div class="card-body">
                    <div class="card-label">Bền vững</div>
                    <h3 class="card-heading">Cam kết xanh</h3>
                    <p class="card-text">Hỗ trợ phát triển bền vững và giảm tác động lên môi trường.</p>
                </div>
            </article>
            <article class="card-tile">
                <img src="https://doanhnhanplus.vn/wp-content/uploads/2017/04/Levis-501-Skinny-Jeans-Launch.jpg" alt="Community">
                <div class="card-body">
                    <div class="card-label">Cộng đồng</div>
                    <h3 class="card-heading">Khách hàng là trung tâm</h3>
                    <p class="card-text">Dịch vụ chăm sóc tận tâm và chính sách hỗ trợ thân thiện.</p>
                </div>
            </article>
        </div>
    </section>

    <%- include('chan_trang') %>
</body>

</html>
