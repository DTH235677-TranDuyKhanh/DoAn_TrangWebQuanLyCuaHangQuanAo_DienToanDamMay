<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Kết quả tìm kiếm">
    <title><%= title || 'Kết quả tìm kiếm' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <%- include('styles') %>
</head>

<body>
    <%- include('thanh_menu') %>

    <section class="page-section">
        <h1 class="page-title"><%= title || 'Kết quả tìm kiếm' %></h1>
        <p class="page-copy">Kết quả tìm kiếm cho: "<%= query || '' %>"</p>
        <div class="cards-grid">
            <% if (results && results.length) { %>
                <% results.forEach(function(item) { %>
                    <article class="card-tile">
                        <img src="<%= (item.images && item.images[0]) || 'https://images.unsplash.com/photo-1512436991641-6745cdb1723f?w=900&h=1200&fit=crop' %>" alt="<%= item.name || item.title %>" onerror="this.onerror=null;this.src='https://via.placeholder.com/600x600?text=No+Image'">
                        <div class="card-body">
                            <div class="card-label"><%= item.category && item.category.name ? item.category.name : 'Sản phẩm' %></div>
                            <h3 class="card-heading"><%= item.name || item.title %></h3>
                            <p class="card-text"><%= item.description ? (item.description.length > 120 ? item.description.substring(0, 120) + '...' : item.description) : 'Không có mô tả.' %></p>
                            <a class="card-link" href="/san-pham/<%= item.slug %>">Xem chi tiết</a>
                        </div>
                    </article>
                <% }); %>
            <% } else { %>
                <div class="alert">Không tìm thấy kết quả nào phù hợp.</div>
            <% } %>
        </div>
    </section>

    <%- include('chan_trang') %>
</body>

</html>
