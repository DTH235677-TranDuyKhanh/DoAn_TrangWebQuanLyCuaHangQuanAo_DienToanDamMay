<style>
:root {
    --bg: #faf7ef;
    --surface: #f4efe6;
    --white: #ffffff;
    --black: #1a1a1a;
    --red: #e4002b;
    --gray: #707070;
    --border: rgba(0, 0, 0, 0.08);
    --shadow: 0 28px 60px rgba(0, 0, 0, 0.08);
    --transition: all 0.25s ease;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    min-height: 100vh;
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--black);
    background: var(--bg);
}

a {
    color: inherit;
    text-decoration: none;
}

button {
    font: inherit;
    border: none;
    background: none;
    cursor: pointer;
}

.top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 40px;
    background: var(--white);
    border-bottom: 1px solid var(--border);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 12px;
    font-weight: 700;
    position: sticky;
    top: 0;
    z-index: 1000;
}

.top-bar-center {
    flex: 1;
    text-align: center;
}

.top-bar-center a {
    text-decoration: underline;
    font-weight: 900;
    margin-left: 8px;
}

.top-bar-icon,
.header-icon {
    width: 36px;
    height: 36px;
    border: 1px solid var(--border);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
}

.top-bar-icon:hover,
.header-icon:hover {
