    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 12px;
    font-weight: 800;
}

.card-heading {
    font-size: 20px;
    font-weight: 800;
    margin-bottom: 14px;
}

.card-text {
    color: var(--gray);
    font-size: 14px;
    line-height: 1.8;
    margin-bottom: 18px;
}

.card-link {
    font-size: 12px;
    font-weight: 700;
    color: var(--black);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    text-decoration: underline;
}

.highlight-row {
