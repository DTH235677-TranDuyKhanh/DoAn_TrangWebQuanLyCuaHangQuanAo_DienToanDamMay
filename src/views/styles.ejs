}

.hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s ease;
}

.hero-left:hover img,
.hero-right:hover img {
    transform: scale(1.05);
}

.hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.12) 0%, rgba(0, 0, 0, 0.45) 100%);
    pointer-events: none;
}

.hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    z-index: 1;
    padding: 0 24px;
}

.hero-content-inner {
    max-width: 580px;
    color: var(--white);
}

.hero-label {
    font-size: 12px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    opacity: 0.85;
    margin-bottom: 16px;
}

.hero-title {
    font-size: 60px;
    font-weight: 900;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    margin-bottom: 26px;
