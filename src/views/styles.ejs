    top: 48px;
    z-index: 999;
}

.header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
    padding: 12px 30px;
    min-height: 56px;
}

.brand-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: transparent;
    color: inherit;
    text-transform: none;
}

.brand-logo img {
    display: block;
    max-height: 80px;
    width: auto;
}

.nav-menu {
    display: flex;
    gap: 42px;
    list-style: none;
    flex: 1;
    justify-content: center;
}

.nav-menu li a {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--black);
