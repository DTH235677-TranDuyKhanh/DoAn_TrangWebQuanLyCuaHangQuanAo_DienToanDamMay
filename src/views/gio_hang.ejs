<!-- View Giỏ hàng: hiển thị sản phẩm đã thêm và liên kết tới thanh toán. --><!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Giỏ hàng của bạn">
    <title><%= title || 'Giỏ hàng' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <%- include('styles') %>
</head>

<body>
    <%- include('thanh_menu') %>

    <section class="page-section">
        <h1 class="page-title"><%= title || 'Giỏ hàng' %></h1>
        <p class="page-copy">Xem lại các sản phẩm bạn đã thêm vào giỏ hàng trước khi tiến hành thanh toán.</p>
        <div class="panel">
            <div class="panel-body">
                <!-- Nếu giỏ hàng có item thì hiển thị bảng chi tiết đơn hàng. -->
                <% if (cart && cart.items.length) { %>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Giá</th>
                                <th>Số lượng</th>
                                <th>Tổng</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% cart.items.forEach(function(item, index) { %>
                                <tr>
                                    <td>
                                        <strong><%= item.name %></strong>
                                        <!-- Nếu có size hoặc màu thì hiển thị thêm chi tiết. -->
                                        <% if (item.size) { %><div>Kích thước: <%= item.size %></div><% } %>
                                        <% if (item.color) { %><div>Màu: <%= item.color %></div><% } %>
                                    </td>
                                    <td><%= item.price.toLocaleString() %> ₫</td>
                                    <td><%= item.quantity %></td>
                                    <td><%= (item.total || item.price * item.quantity).toLocaleString() %> ₫</td>
                                    <td>
                                        <a href="/don-hang/gio-hang/xoa/<%= index %>" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này?')">
                                            <i class="bi bi-trash"></i> Xóa
                                        </a>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                    <div class="cart-summary">
                        <p><strong>Tổng đơn hàng:</strong> <%= cart.totalPrice.toLocaleString() %> ₫</p>
                    </div>
                    <div class="form-actions">
                        <a href="/don-hang/thanh-toan" class="button-primary">Tiến hành thanh toán</a>
                    </div>
                <% } else { %>
                    <!-- Nếu giỏ hàng trống, thông báo sẽ hiện ra thay vì bảng chi tiết. -->
                    <div class="alert">Giỏ hàng của bạn đang trống.</div>
                <% } %>
            </div>
        </div>
    </section>

    <%- include('chan_trang') %>
</body>

</html>
