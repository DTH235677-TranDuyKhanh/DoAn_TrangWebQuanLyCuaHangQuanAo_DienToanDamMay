<!-- View admin dashboard: bảng điều khiển tổng quan của quản trị viên. --><!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Bảng điều khiển quản lý">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <%- include('styles') %>
</head>

<body>
    <%- include('thanh_menu') %>

    <section class="page-section">
        <h1 class="page-title"><%= title %></h1>
        <p class="page-copy">Chỉ những tài khoản quản lý mới có thể tạo, sửa và xóa sản phẩm hoặc danh mục.</p>
        <!-- Bảng tổng quan nhanh: số lượng sản phẩm và danh mục hiện có -->
        <div class="grid-2">
            <div class="panel">
                <div class="panel-body">
                    <h2 class="panel-heading">Sản phẩm</h2>
                    <p class="page-copy">Hiện có <strong><%= productCount %></strong> sản phẩm trong kho.</p>
                    <div class="form-actions">
                        <a href="/admin/products" class="button-primary">Quản lý sản phẩm</a>
                    </div>
                </div>
            </div>
            <div class="panel">
                <div class="panel-body">
                    <h2 class="panel-heading">Danh mục</h2>
                    <p class="page-copy">Hiện có <strong><%= categoryCount %></strong> danh mục.</p>
                    <div class="form-actions">
                        <a href="/admin/categories" class="button-primary">Quản lý danh mục</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('chan_trang') %>
</body>

</html>
