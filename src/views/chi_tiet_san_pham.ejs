<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Chi tiết sản phẩm">
    <title><%= title || 'Chi tiết sản phẩm' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <%- include('styles') %>
</head>

<body>
    <%- include('thanh_menu') %>

    <section class="page-section">
        <div class="product-card">
            <div class="product-gallery">
                <img src="<%= (product.images && product.images[0]) || 'https://images.unsplash.com/photo-1512436991641-6745cdb1723f?w=900&h=1200&fit=crop' %>" alt="<%= product ? product.name : 'Sản phẩm' %>" onerror="this.onerror=null;this.src='https://via.placeholder.com/600x600?text=No+Image'">
                <div class="product-preview">
                    <% if (product && product.images) { %>
                        <% product.images.slice(1, 4).forEach(function(image) { %>
                            <img src="<%= image %>" alt="Preview" onerror="this.onerror=null;this.src='https://via.placeholder.com/200x200?text=No+Image'">
                        <% }); %>
                    <% } %>
                </div>
            </div>
            <div class="product-preview">
                <h1 class="product-heading"><%= product ? product.name : 'Sản phẩm chưa xác định' %></h1>
                <div class="product-price"><%= product && product.salePrice ? product.salePrice.toLocaleString() + ' ₫' : (product && product.price ? product.price.toLocaleString() + ' ₫' : 'Liên hệ') %></div>
                <p class="product-description"><%= product ? (product.description || 'Mô tả chi tiết sản phẩm sẽ được cập nhật sớm.') : 'Không có thông tin sản phẩm.' %></p>
                <div class="tag-list">
                    <% if (product && product.sizes) { %>
                        <% product.sizes.forEach(function(size) { %>
                            <span class="tag-pill"><%= size %></span>
                        <% }); %>
                    <% } %>
                </div>
                <div class="tag-list">
                    <% if (product && product.colors) { %>
                        <% product.colors.forEach(function(color) { %>
                            <span class="tag-pill"><%= color %></span>
                        <% }); %>
                    <% } %>
                </div>
                <form action="/don-hang/gio-hang/them" method="post">
                    <input type="hidden" name="productId" value="<%= product._id %>">
                    <div class="form-group">
                        <label for="quantity">Số lượng</label>
                        <input type="number" id="quantity" name="quantity" min="1" value="1">
                    </div>
                    <% if (product && product.sizes && product.sizes.length) { %>
                        <div class="form-group">
                            <label for="size">Kích thước</label>
                            <select id="size" name="size">
                                <% product.sizes.forEach(function(size) { %>
                                    <option value="<%= size %>"><%= size %></option>
                                <% }); %>
                            </select>
                        </div>
                    <% } %>
                    <% if (product && product.colors && product.colors.length) { %>
                        <div class="form-group">
                            <label for="color">Màu sắc</label>
                            <select id="color" name="color">
                                <% product.colors.forEach(function(color) { %>
                                    <option value="<%= color %>"><%= color %></option>
                                <% }); %>
                            </select>
                        </div>
                    <% } %>
                    <div class="form-actions">
                        <button type="submit" class="button-primary">Thêm vào giỏ hàng</button>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <%- include('chan_trang') %>
</body>

</html>
